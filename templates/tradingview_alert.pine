//@version=5
indicator("XAU/USD Pattern Alerts", overlay=true)

// ─── SETTINGS ───────────────────────────────────────────────
webhook_url = "https://YOUR-APP.onrender.com/webhook"  // <-- remplace avec ton URL Render

// ─── PATTERN DETECTION ───────────────────────────────────────

// Bullish Engulfing
bullEngulf = close[1] < open[1] and close > open and close > open[1] and open < close[1]

// Bearish Engulfing
bearEngulf = close[1] > open[1] and close < open and close < open[1] and open > close[1]

// Hammer (mèche basse longue, petit corps en haut)
bodySize = math.abs(close - open)
lowerWick = open > close ? close - low : open - low
hammer = lowerWick > bodySize * 2 and close > open

// Shooting Star (mèche haute longue, petit corps en bas)
upperWick = open > close ? high - open : high - close
shootingStar = upperWick > bodySize * 2 and close < open

// ─── SL / TP AUTOMATIQUES ─────────────────────────────────────
atr = ta.atr(14)

longSL  = low  - atr * 1.5
longTP  = close + atr * 3.0
longRR  = (longTP - close) / (close - longSL)

shortSL = high + atr * 1.5
shortTP = close - atr * 3.0
shortRR = (close - shortTP) / (shortSL - close)

// ─── ALERTS ──────────────────────────────────────────────────

// Bullish Engulfing → BUY
if bullEngulf
    alert('{"type":"pattern","pattern":"Bullish Engulfing","action":"BUY","price":' + str.tostring(close, "#.##") + ',"sl":' + str.tostring(longSL, "#.##") + ',"tp":' + str.tostring(longTP, "#.##") + ',"rr":' + str.tostring(longRR, "#.#") + '}', alert.freq_once_per_bar)

// Bearish Engulfing → SELL
if bearEngulf
    alert('{"type":"pattern","pattern":"Bearish Engulfing","action":"SELL","price":' + str.tostring(close, "#.##") + ',"sl":' + str.tostring(shortSL, "#.##") + ',"tp":' + str.tostring(shortTP, "#.##") + ',"rr":' + str.tostring(shortRR, "#.#") + '}', alert.freq_once_per_bar)

// Hammer → BUY
if hammer
    alert('{"type":"pattern","pattern":"Hammer","action":"BUY","price":' + str.tostring(close, "#.##") + ',"sl":' + str.tostring(longSL, "#.##") + ',"tp":' + str.tostring(longTP, "#.##") + ',"rr":' + str.tostring(longRR, "#.#") + '}', alert.freq_once_per_bar)

// Shooting Star → SELL
if shootingStar
    alert('{"type":"pattern","pattern":"Shooting Star","action":"SELL","price":' + str.tostring(close, "#.##") + ',"sl":' + str.tostring(shortSL, "#.##") + ',"tp":' + str.tostring(shortTP, "#.##") + ',"rr":' + str.tostring(shortRR, "#.#") + '}', alert.freq_once_per_bar)

// ─── VISUALS ──────────────────────────────────────────────────
plotshape(bullEngulf, title="Bull Engulf",  location=location.belowbar, color=color.teal,  style=shape.triangleup,   size=size.small)
plotshape(bearEngulf, title="Bear Engulf",  location=location.abovebar, color=color.red,   style=shape.triangledown, size=size.small)
plotshape(hammer,     title="Hammer",       location=location.belowbar, color=color.green, style=shape.labelup,      size=size.tiny)
plotshape(shootingStar, title="ShootingStar", location=location.abovebar, color=color.orange, style=shape.labeldown, size=size.tiny)
